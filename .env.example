# LLM providers (pluggable — set the ones you use)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Which provider the agents default to: "openai" | "gemini"
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# Search
TAVILY_API_KEY=

# Tracing (optional — leave blank to log locally only)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Gates
ATS_PASS_THRESHOLD=70

# Local data store (resumes, postings, traces — never sent to third parties)
JOBPILOT_DATA_DIR=.jobpilot_data

# Application Agent auto-submit allow-list (comma-separated hostnames)
AUTO_SUBMIT_ALLOWLIST=

# API
API_HOST=0.0.0.0
API_PORT=8000

# Optional durable Postgres checkpointing + admin run-log (any Postgres,
# e.g. Neon). Leave blank to run with in-memory checkpointing only.
DATABASE_URL=
DATABASE_SCHEMA=jobpilot

# Admin dashboard (HTTP Basic Auth) — change these before deploying anywhere real
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
